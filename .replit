modules = ["nodejs-20", "java-graalvm22.3", "python-3.12", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && PUPPETEER_SKIP_DOWNLOAD=true PORT=5000 npx vite --mode core --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "cd frontend && PUPPETEER_SKIP_DOWNLOAD=true npm install --no-fund --no-audit && node scripts/generate-icons.js && npx vite build --mode core"]
publicDir = "frontend/dist"
